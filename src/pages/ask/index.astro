---
import PortfolioLayout from '~/layouts/PortfolioLayout.astro';
import FitAgent from '~/components/portfolio/FitAgent.astro';
import { site, experience, heroSkills, techStack } from '~/data/site';
import { projects } from '~/data/projects';
import type { AgentProfile } from '~/utils/fitAgent';

const metadata = {
  title: 'Ask the Fit Agent',
  description: `Ask whether ${site.name} is a good fit for a role, or question the portfolio about experience and skills.`,
};

const profile: AgentProfile = {
  name: site.name,
  title: site.title,
  bio: site.bio,
  location: site.location,
  employer: site.employer,
  education: site.education,
  email: site.email,
  linkedin: site.linkedin,
  github: site.github,
  skills: [...new Set([...heroSkills, ...techStack.flatMap((g) => g.items)])],
  experience,
  projects: projects.map(({ title, description, tags }) => ({ title, description, tags })),
};
---

<PortfolioLayout metadata={metadata}>
  <div class="mx-auto max-w-3xl px-4 py-12 sm:px-6 sm:py-16">
    <FitAgent profile={profile} />

    <section class="mt-12 rounded-xl border border-slate-200/90 bg-white/80 p-4 shadow-sm dark:border-slate-700/80 dark:bg-slate-900/50 sm:p-6">
      <p class="text-sm font-semibold uppercase tracking-widest text-primary">Hugging Face Space</p>
      <h2 class="mt-1 font-heading text-xl font-bold text-heading">Anest58Ask (Gradio)</h2>
      <p class="mt-2 text-sm text-muted">
        Same fit agent hosted on Hugging Face for sharing and embedding. Source lives in this repo under
        <code class="rounded bg-slate-200 px-1 text-xs dark:bg-slate-800">spaces/anest58Ask/</code>.
      </p>
      <div class="mt-4 overflow-hidden rounded-lg border border-slate-200 dark:border-slate-700">
        <iframe
          title="Anest58Ask Hugging Face Space"
          src="https://andominus58-anest58ask.hf.space"
          class="h-[640px] w-full bg-white"
          loading="lazy"
        ></iframe>
      </div>
      <p class="mt-3 text-sm">
        <a
          class="font-semibold text-primary hover:underline"
          href="https://huggingface.co/spaces/Andominus58/anest58Ask"
          target="_blank"
          rel="noopener noreferrer"
        >
          Open on Hugging Face →
        </a>
      </p>
    </section>

    <p class="mt-8 text-center text-sm text-muted">
      <a class="font-semibold text-primary hover:underline" href="/">← Back to portfolio</a>
      ·
      <a class="font-semibold text-primary hover:underline" href={site.resumeUrl} download>Download resume</a>
    </p>
  </div>
</PortfolioLayout>

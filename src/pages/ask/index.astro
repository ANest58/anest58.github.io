---
import PortfolioLayout from '~/layouts/PortfolioLayout.astro';
import { site } from '~/data/site';

const metadata = {
  title: 'Ask Anthony',
  description: `Ask whether ${site.name} is a good fit for a role, or question the portfolio about experience and skills.`,
};
---

<PortfolioLayout metadata={metadata}>
  <div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 sm:py-16">
    <header class="mb-8 max-w-3xl">
      <p class="text-sm font-semibold uppercase tracking-widest text-primary">Ask</p>
      <h1 class="mt-2 font-heading text-3xl font-bold tracking-tight text-heading sm:text-4xl">
        Ask about {site.name}
      </h1>
      <p class="mt-3 text-muted">
        Portfolio Q&amp;A powered by a real LLM on Hugging Face. Paste a job description to check fit, or ask about
        experience, skills, and projects.
      </p>
    </header>

    <section
      class="rounded-xl border border-slate-200/90 bg-white/80 p-2 shadow-sm dark:border-slate-700/80 dark:bg-slate-900/50 sm:p-3"
    >
      <div class="overflow-hidden rounded-lg border border-slate-200 dark:border-slate-700">
        <iframe
          title="Anest58Ask Hugging Face Space"
          src="https://andominus58-anest58ask.hf.space"
          class="h-[min(80vh,900px)] w-full bg-white"
          loading="lazy"></iframe>
      </div>
      <p class="mt-3 text-sm">
        <a
          class="font-semibold text-primary hover:underline"
          href="https://huggingface.co/spaces/Andominus58/anest58Ask"
          target="_blank"
          rel="noopener noreferrer"
        >
          Open on Hugging Face →
        </a>
      </p>
    </section>

    <p class="mt-8 text-center text-sm text-muted">
      <a class="font-semibold text-primary hover:underline" href="/">← Back to portfolio</a>
      ·
      <a class="font-semibold text-primary hover:underline" href={site.resumeUrl} download>Download resume</a>
    </p>
  </div>
</PortfolioLayout>

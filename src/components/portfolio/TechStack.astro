---
import { techStack } from '~/data/site';

const reveal = 'intersect-once intersect-third motion-safe:opacity-0 motion-safe:intersect:animate-fade';
---

<section id="tech" class="scroll-mt-24 mx-auto max-w-5xl px-4 py-16 sm:px-6">
  <div class={reveal}>
    <p class="text-sm font-semibold uppercase tracking-widest text-primary">Stack</p>
    <h2 class="mt-2 font-heading text-3xl font-bold tracking-tight text-heading">Tech stack</h2>
    <p class="mt-3 max-w-2xl text-muted">
      Technologies I use for scientific AI, data engineering, and production tooling.
    </p>
  </div>

  <div class="mt-10 grid gap-6 sm:grid-cols-2">
    {
      techStack.map((group) => (
        <div
          class={`rounded-lg border border-slate-200/90 bg-white/80 p-5 shadow-sm dark:border-slate-700/80 dark:bg-slate-900/50 ${reveal}`}
        >
          <h3 class="mb-3 text-sm font-semibold uppercase tracking-wide text-heading">{group.group}</h3>
          <ul class="flex flex-wrap gap-2">
            {group.items.map((item) => (
              <li class="rounded-md border border-slate-200 px-2.5 py-1 text-sm text-default dark:border-slate-700">
                {item}
              </li>
            ))}
          </ul>
        </div>
      ))
    }
  </div>
</section>

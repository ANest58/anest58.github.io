---
import { site, heroSkills } from '~/data/site';
---

<section class="relative mx-auto max-w-5xl px-4 pb-16 pt-16 sm:px-6 sm:pt-24">
  <p class="mb-4 text-sm font-semibold uppercase tracking-widest text-primary">{site.availability}</p>

  <h1 class="font-heading text-4xl font-bold tracking-tight text-heading sm:text-5xl md:text-6xl">
    Hey, I'm {site.name}
  </h1>

  <p class="mt-4 max-w-2xl text-xl font-medium text-default sm:text-2xl">{site.title}</p>

  <p class="mt-5 max-w-2xl text-base leading-relaxed text-muted sm:text-lg">{site.bio}</p>

  <ul class="mt-8 flex flex-wrap gap-2" aria-label="Core skills">
    {
      heroSkills.map((skill) => (
        <li class="rounded-md border border-slate-200 bg-white/70 px-3 py-1 text-sm text-default dark:border-slate-700 dark:bg-slate-900/60">
          {skill}
        </li>
      ))
    }
  </ul>

  <div class="mt-10 flex flex-wrap gap-3">
    <a
      href="#contact"
      class="inline-flex items-center justify-center rounded-md bg-primary px-5 py-2.5 text-sm font-semibold text-white transition hover:bg-secondary"
    >
      Get in touch
    </a>
    <a
      href="#projects"
      class="inline-flex items-center justify-center rounded-md border border-slate-300 bg-transparent px-5 py-2.5 text-sm font-semibold text-default transition hover:border-primary hover:text-primary dark:border-slate-600"
    >
      View projects
    </a>
  </div>
</section>

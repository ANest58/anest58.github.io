---
import type { AgentProfile } from '~/utils/fitAgent';
import { hfAgent } from '~/data/hfAgent';
import { getSpaceAppUrl, getSpaceEmbedUrl } from '~/utils/hfChat';

export interface Props {
  profile: AgentProfile;
}

const { profile } = Astro.props;

const suggestions = [
  'Is this candidate a good fit for this position?',
  'Summarize AI and data enablement experience',
  'What projects involve RAG or multi-agent systems?',
  'How can I contact Anthony?',
];

const buildTimeToken = (import.meta.env.PUBLIC_HF_TOKEN as string | undefined)?.trim() || '';
const buildTimeModel = (import.meta.env.PUBLIC_HF_MODEL as string | undefined)?.trim() || hfAgent.model;
const spaceId = (import.meta.env.PUBLIC_HF_SPACE_ID as string | undefined)?.trim() || hfAgent.spaceId;
const spaceAppUrl = getSpaceAppUrl(spaceId);
const spacePageUrl = getSpaceEmbedUrl(spaceId);
const preferSpaceEmbed = Boolean(spaceAppUrl);
---

<section
  id="fit-agent"
  class="rounded-xl border border-slate-200/90 bg-white/80 shadow-sm backdrop-blur-sm dark:border-slate-700/80 dark:bg-slate-900/50"
  data-profile={JSON.stringify(profile)}
  data-token-key={hfAgent.tokenStorageKey}
  data-model={buildTimeModel}
  data-hf-token={buildTimeToken}
  data-space-id={spaceId}
>
  <div class="border-b border-slate-200 px-4 py-4 dark:border-slate-700 sm:px-6">
    <p class="text-sm font-semibold uppercase tracking-widest text-primary">Fit agent</p>
    <h1 class="mt-1 font-heading text-2xl font-bold text-heading sm:text-3xl">Ask about {profile.name}</h1>
    <p class="mt-2 text-sm text-muted">
      Paste a job description and ask if the candidate is a good fit, or ask about experience, skills, and projects.
      Connect a free Hugging Face Inference token for an LLM-powered reply, or use the built-in local agent.
    </p>
  </div>

  {
    preferSpaceEmbed && spaceAppUrl ? (
      <div class="border-b border-slate-200 px-4 py-4 dark:border-slate-700 sm:px-6">
        <p class="mb-3 text-sm text-muted">
          Live agent hosted on Hugging Face Spaces
          {spacePageUrl && (
            <>
              {' '}
              (
              <a
                class="font-semibold text-primary hover:underline"
                href={spacePageUrl}
                target="_blank"
                rel="noopener noreferrer"
              >
                open Space
              </a>
              ).
            </>
          )}
        </p>
        <iframe
          title="Hugging Face portfolio fit agent"
          src={spaceAppUrl}
          class="h-[40rem] w-full rounded-lg border border-slate-200 bg-white dark:border-slate-700"
          allow="clipboard-write; fullscreen"
          loading="lazy"
        />
      </div>
    ) : (
      <>
        <details class="border-b border-slate-200 px-4 py-3 dark:border-slate-700 sm:px-6">
          <summary class="cursor-pointer text-sm font-semibold text-heading">Connect free Hugging Face LLM</summary>
          <div class="mt-3 space-y-3 text-sm text-muted">
            <p>
              1. Create a fine-grained token with Inference Providers access:{' '}
              <a
                class="font-semibold text-primary hover:underline"
                href="https://huggingface.co/settings/tokens/new?ownUserPermissions=inference.serverless.write&tokenType=fineGrained"
                target="_blank"
                rel="noopener noreferrer"
              >
                huggingface.co/settings/tokens
              </a>
              .
            </p>
            <p>
              2. Paste the token below (kept in this browser only). Or set <code class="text-xs">PUBLIC_HF_TOKEN</code>{' '}
              at build time. Optional model override via <code class="text-xs">PUBLIC_HF_MODEL</code>.
            </p>
            <p>
              3. To host the agent on your Hugging Face site, deploy the <code class="text-xs">hf-space/</code> folder
              as a Gradio Space, then set <code class="text-xs">PUBLIC_HF_SPACE_ID=your-user/portfolio-fit-agent</code>.
            </p>
            <label class="block">
              <span class="sr-only">Hugging Face token</span>
              <input
                id="hf-token-input"
                type="password"
                autocomplete="off"
                placeholder="hf_… fine-grained token"
                class="w-full rounded-lg border border-slate-300 bg-page px-3 py-2 text-sm text-default outline-none ring-primary focus:ring-2 dark:border-slate-600"
              />
            </label>
            <div class="flex flex-wrap items-center gap-2">
              <button
                type="button"
                id="hf-token-save"
                class="rounded-md bg-primary px-3 py-1.5 text-xs font-semibold text-white transition hover:bg-secondary"
              >
                Save token
              </button>
              <button
                type="button"
                id="hf-token-clear"
                class="rounded-md border border-slate-300 px-3 py-1.5 text-xs font-medium text-default transition hover:border-primary dark:border-slate-600"
              >
                Clear
              </button>
              <span id="hf-status" class="text-xs text-muted" aria-live="polite">
                Using local agent (no HF token).
              </span>
            </div>
          </div>
        </details>

        <div class="flex flex-wrap gap-2 border-b border-slate-200 px-4 py-3 dark:border-slate-700 sm:px-6">
          {suggestions.map((s) => (
            <button
              type="button"
              class="suggestion rounded-md border border-slate-200 px-2.5 py-1 text-left text-xs text-default transition hover:border-primary hover:text-primary dark:border-slate-600"
              data-suggestion={s}
            >
              {s}
            </button>
          ))}
        </div>

        <div
          id="agent-log"
          class="flex max-h-[28rem] min-h-[16rem] flex-col gap-3 overflow-y-auto px-4 py-4 sm:px-6"
          aria-live="polite"
        >
          <div class="max-w-[90%] rounded-lg bg-slate-100 px-3 py-2 text-sm text-default dark:bg-slate-800">
            Hi — I’m a portfolio fit agent for <strong>{profile.name}</strong>. Paste a JD and ask about fit, or ask a
            question about their background. Connect a free Hugging Face token above for LLM answers.
          </div>
        </div>

        <form id="agent-form" class="border-t border-slate-200 p-4 dark:border-slate-700 sm:p-6">
          <label class="sr-only" for="agent-input">
            Your question or job description
          </label>
          <textarea
            id="agent-input"
            rows="5"
            class="w-full rounded-lg border border-slate-300 bg-page px-3 py-2 text-sm text-default outline-none ring-primary focus:ring-2 dark:border-slate-600"
            placeholder="Example: paste a job description here, then ask — Is this candidate a good fit for this position?"
          />
          <div class="mt-3 flex flex-wrap items-center gap-3">
            <button
              type="submit"
              id="agent-submit"
              class="rounded-md bg-primary px-4 py-2 text-sm font-semibold text-white transition hover:bg-secondary disabled:opacity-60"
            >
              Ask agent
            </button>
            <button
              type="button"
              id="agent-clear"
              class="rounded-md border border-slate-300 px-4 py-2 text-sm font-medium text-default transition hover:border-primary dark:border-slate-600"
            >
              Clear
            </button>
          </div>
        </form>
      </>
    )
  }
</section>

<script>
  import { runFitAgent, type AgentProfile } from '~/utils/fitAgent';
  import { chatWithHuggingFace } from '~/utils/hfChat';

  const root = document.getElementById('fit-agent');
  const log = document.getElementById('agent-log');
  const form = document.getElementById('agent-form') as HTMLFormElement | null;
  const input = document.getElementById('agent-input') as HTMLTextAreaElement | null;
  const clearBtn = document.getElementById('agent-clear');
  const submitBtn = document.getElementById('agent-submit') as HTMLButtonElement | null;
  const tokenInput = document.getElementById('hf-token-input') as HTMLInputElement | null;
  const tokenSave = document.getElementById('hf-token-save');
  const tokenClear = document.getElementById('hf-token-clear');
  const statusEl = document.getElementById('hf-status');

  // No-op when the Space iframe mode is active (chat form is not rendered).
  if (root && log && form && input) {
    const profile = JSON.parse(root.dataset.profile || '{}') as AgentProfile;
    const tokenKey = root.dataset.tokenKey || 'aw_hf_inference_token';
    const model = root.dataset.model || 'Qwen/Qwen2.5-7B-Instruct:fastest';
    const buildToken = root.dataset.hfToken?.trim() || '';

    const getStoredToken = () => {
      try {
        return localStorage.getItem(tokenKey)?.trim() || '';
      } catch {
        return '';
      }
    };

    const resolveToken = () => getStoredToken() || buildToken;

    const setStatus = (text: string) => {
      if (statusEl) statusEl.textContent = text;
    };

    const refreshStatus = () => {
      if (getStoredToken()) setStatus('Hugging Face LLM ready (browser token).');
      else if (buildToken) setStatus('Hugging Face LLM ready (build-time token).');
      else setStatus('Using local agent (no HF token).');
    };

    if (tokenInput) tokenInput.value = getStoredToken();
    refreshStatus();

    tokenSave?.addEventListener('click', () => {
      const value = tokenInput?.value.trim() || '';
      try {
        if (value) localStorage.setItem(tokenKey, value);
        else localStorage.removeItem(tokenKey);
      } catch {
        /* ignore storage errors */
      }
      refreshStatus();
    });

    tokenClear?.addEventListener('click', () => {
      if (tokenInput) tokenInput.value = '';
      try {
        localStorage.removeItem(tokenKey);
      } catch {
        /* ignore */
      }
      refreshStatus();
    });

    const append = (role: 'user' | 'agent', text: string) => {
      const bubble = document.createElement('div');
      bubble.className =
        role === 'user'
          ? 'ml-auto max-w-[90%] rounded-lg bg-primary px-3 py-2 text-sm text-white whitespace-pre-wrap'
          : 'max-w-[90%] rounded-lg bg-slate-100 px-3 py-2 text-sm text-default dark:bg-slate-800 whitespace-pre-wrap';
      bubble.textContent = text;
      log.appendChild(bubble);
      log.scrollTop = log.scrollHeight;
      return bubble;
    };

    const ask = async (message: string) => {
      const trimmed = message.trim();
      if (!trimmed) return;
      append('user', trimmed);
      input.value = '';

      const pending = append('agent', 'Thinking…');
      if (submitBtn) submitBtn.disabled = true;

      const token = resolveToken();
      let reply: string;

      if (token) {
        const result = await chatWithHuggingFace({
          token,
          userMessage: trimmed,
          profile,
          model,
        });
        if (result.ok) {
          reply = result.content;
        } else {
          reply = `${result.error}\n\nFalling back to local agent:\n\n${runFitAgent(profile, trimmed)}`;
        }
      } else {
        reply = runFitAgent(profile, trimmed);
      }

      pending.textContent = reply;
      if (submitBtn) submitBtn.disabled = false;
      log.scrollTop = log.scrollHeight;
    };

    form.addEventListener('submit', (event) => {
      event.preventDefault();
      void ask(input.value);
    });

    clearBtn?.addEventListener('click', () => {
      log.innerHTML = '';
      append(
        'agent',
        `Hi — I’m a portfolio fit agent for ${profile.name}. Paste a JD and ask about fit, or ask a question about their background. Connect a free Hugging Face token above for LLM answers.`
      );
    });

    root.querySelectorAll<HTMLButtonElement>('[data-suggestion]').forEach((btn) => {
      btn.addEventListener('click', () => {
        const suggestion = btn.dataset.suggestion || '';
        if (suggestion.toLowerCase().includes('good fit')) {
          input.value = `${suggestion}\n\n(Paste the job description below this line)\n\n`;
          input.focus();
        } else {
          void ask(suggestion);
        }
      });
    });
  }
</script>
